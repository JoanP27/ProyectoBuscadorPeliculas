{# Recibe: c (el comentario actual, del for loop en films_ficha.njk) #}

<dialog id="modalEditar-{{ c._id }}"
    class="rounded-2xl shadow-xl p-0 w-full max-w-lg backdrop:bg-black/50">
    <div class="bg-white rounded-2xl overflow-hidden">
        <div class="bg-gray-800 px-6 py-4">
            <h3 class="text-lg font-semibold text-white">Editar comentario</h3>
        </div>

        <form action="/details/{{ c._id }}" method="post" class="px-6 py-4 space-y-4">
            <input type="hidden" name="_method" value="put">

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Comentario:</label>
                <textarea name="texto" required rows="4"
                    class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none">{{ c.texto }}</textarea>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Valoración:</label>
                <select name="valoracion" required
                    class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="1" {% if c.valoracion == 1 %}selected{% endif %}>1 ⭐ - Muy mala</option>
                    <option value="2" {% if c.valoracion == 2 %}selected{% endif %}>2 ⭐⭐ - Mala</option>
                    <option value="3" {% if c.valoracion == 3 %}selected{% endif %}>3 ⭐⭐⭐ - Regular</option>
                    <option value="4" {% if c.valoracion == 4 %}selected{% endif %}>4 ⭐⭐⭐⭐ - Buena</option>
                    <option value="5" {% if c.valoracion == 5 %}selected{% endif %}>5 ⭐⭐⭐⭐⭐ - Excelente</option>
                </select>
            </div>
            <div class="flex justify-end gap-3 pt-2">
                <button type="button"
                    onclick="document.getElementById('modalEditar-{{ c._id }}').close()"
                    class="bg-slate-200 hover:bg-slate-300 text-slate-700
                           font-semibold py-2 px-4 rounded-xl text-sm">
                    Cancelar
                </button>
                <button type="submit"
                    class="bg-blue-600 hover:bg-blue-700 text-white
                           font-semibold py-2 px-4 rounded-xl text-sm">
                    Guardar cambios
                </button>
            </div>
        </form>
    </div>
</dialog>