{# Recibe: film (del scope de films_ficha.njk) #}

<button onclick="document.getElementById('modalComentario').showModal()"
    class="bg-blue-700 hover:bg-blue-500 text-white font-semibold py-2 px-4 rounded-xl">
    <span class="icon-[material-symbols--comment]"></span> Añadir comentario
</button>

<dialog id="modalComentario"
    class="rounded-2xl shadow-xl p-0 w-full max-w-lg backdrop:bg-black/50">
    <div class="bg-white rounded-2xl overflow-hidden">
        <div class="bg-gray-800 px-6 py-4">
            <h3 class="text-lg font-semibold text-white">Publicar comentario</h3>
        </div>


        <form action="/details/nuevo/{{ film.id }}" method="post" class="px-6 py-4 space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Tu nombre (nick):</label>
                <input type="text" name="nick" required
                    placeholder="¿Cómo te llamas?..."
                    class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Comentario:</label>
                <textarea name="texto" required rows="4"
                    placeholder="¿Qué opinas de la película?..."
                    class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Valoración:</label>
                <select name="valoracion" required
                    class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">Elige una valoración</option>
                    <option value="1">1 ⭐ - Muy mala</option>
                    <option value="2">2 ⭐⭐ - Mala</option>
                    <option value="3">3 ⭐⭐⭐ - Regular</option>
                    <option value="4">4 ⭐⭐⭐⭐ - Buena</option>
                    <option value="5">5 ⭐⭐⭐⭐⭐ - Excelente</option>
                </select>
            </div>
            <div class="flex justify-end gap-3 pt-2">
                <button type="button"
                    onclick="document.getElementById('modalComentario').close()"
                    class="bg-slate-200 hover:bg-slate-300 text-slate-700
                           font-semibold py-2 px-4 rounded-xl text-sm">
                    Cancelar
                </button>
                <button type="submit"
                    class="bg-blue-600 hover:bg-blue-700 text-white
                           font-semibold py-2 px-4 rounded-xl text-sm">
                    Publicar
                </button>
            </div>
        </form>
    </div>
</dialog>