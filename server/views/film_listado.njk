{% extends "base.njk" %}

{% block titulo %}Peliculas | Listado{% endblock %}

{% block scripts %} 

<script type="module" src="http://localhost:5173/js/buscador_peliculas.js"></script>

{% endblock %}

{% block contenido %}

{# Seccion de formulario de busqueda #}
<section class="bg-white/10 rounded-md p-4">

    {# Formulario de busqueda #}
    <form class="flex flex-wrap gap-2" action="/films" method="get" id="formulario-buscador">

        {# Indica la cantidad actual, sirve para enviarle al backend la pagina a mostrar #}
        <input type="hidden" id="paginaABuscar" name="paginaABuscar" value="{{page + 1}}">

        {# Campo de titulo #}
        <section class="text-input p-0 m-0 w-full md:w-auto flex items-center">
            <label for="titulo" class="icon-[streamline-plump--film-slate-remix] size-4 ml-3 bg-gray-400"></label>
            <input value="{{params.titulo}}" placeholder="Titulo" class="p-2 w-full md:w-auto rounded-md outline-0" type="text" name="titulo" id="titulo">
        </section>

        {# Campo de año de publicacion #}
        <section class="text-input p-0 m-0 flex items-center">
            <label for="anyo" class="icon-[mdi--calendar] size-5 ml-3 bg-gray-400"></label>
            <input value='{{params.anyo}}' placeholder="Año" class="p-2 w-30 rounded-md outline-0" min=0 type="number" name="anyo" id="anyo">
        </section>

        {# Campo de director #}
        <section class="text-input p-0 m-0 flex items-center">
            <label for="director" class="icon-[material-symbols--person] size-5 ml-2 bg-gray-400"></label>
            <input value='{{params.director}}' placeholder="Director" class="p-2 w-30 rounded-md outline-0" type="text" name="director" id="director">
        </section>

        {# Campo de orden #}
        <section class="text-input p-0 m-0 flex items-center">
            <label for="orden" class="icon-[mdi--sort-alphabetical-ascending] size-5 ml-2 bg-gray-400"></label>
            <select class="p-2 w-35 rounded-md outline-0 text-gray-400"  type="text" name="orden" id="orden">
                <option {{"selected" if params.orden == "asc"}} value="asc" class="bg-gray-800">Ascendente</option>
                <option {{"selected" if params.orden == "desc"}} value="desc" class="bg-gray-800">Descendente</option>
            </select>
        </section>

        {# Campo de cantidad de resultados por pagina #}
        <section class="text-input p-0 m-0 flex items-center">
            <label for="max-resultados" class="icon-[mdi--format-list-numbered] size-5 ml-2 bg-gray-400"></label>
            <!-- si el valor de limite devuelto del servidor es 10, no se mostrara el valor ya que es el que la base de datos tiene por defecto -->
            <input value='{{limit if limit != 10}}' min="5" max="20" placeholder="Ver 10..." class="p-2 w-30 rounded-md outline-0" type="number" name="max_resultados" id="max-resultados">
        </section>

        {# Boton de buscar #}
        <button type="submit" class="button bg-blue-800/60 text-blue-300 hover:text-white hover:bg-blue-600/70 cursor-pointer">
            <span class="icon-[material-symbols--search] size-5"></span>
            <span>Buscar</span>
        </button>

        {# Boton de limpiar el formulario de busqueda #}
        <button type="reset" class="button bg-red-800/60 text-red-300 hover:text-white hover:bg-red-600/70 cursor-pointer">
            <span class="icon-[pajamas--remove] size-4"></span>
            <span>Limpiar</span>
        </button>
    </form>
</section>

{# Seccion con los componentes de la paginacion #}
<section class="flex flex-row justify-between items-center py-4">

    {# 
        Lista con todas las paginas generadas con los resultados de busqueda, si la web se esta mostrando en movil, 
        solo aparecen los botones de navegacion y el boton de pagina actual
    #}
    <section class="flex flex-row flex-wrap gap-2">

        {# Boton de pagina anterior, si no hay mas paginas antes de esta se muestra desabilitado #}
        {% if page <= 0 or totalPages <= 0 %}
            <button class="p-2 flex justify-center items-center bg-white/10 text-gray-500 rounded-md rounded-bl-xl rounded-tl-xl">
                <span class="icon-[material-symbols--arrow-back]"></span>
            </button>
        {% else %}
            <button class="boton-pagina-anterior p-2 flex justify-center items-center bg-blue-400/40  text-blue-200 rounded-md rounded-bl-xl rounded-tl-xl">
                <span class="icon-[material-symbols--arrow-back]"></span>
            </button>
        {% endif %}

        {# Botones de paginas, el boton con el numero de pagina actual destaca de los demas #}
        {% for p in range(1, totalPages+1) %}
            <div class="{{"hidden md:block" if (page+1) != p}}">
                {% if (page+1) == p %}
                    <button class="py-2 px-4 bg-blue-400/40 text-blue-200 md:scale-105 rounded-md">{{p}}</button>
                {% else %}
                    <button class="boton-pagina py-2 px-4 bg-white/10 hover:bg-white/15 text-gray-500 hover:scale-105 rounded-md">{{p}}</button>
                {% endif %}
            </div>
        {% endfor %}

        {# Boton de pagina anterior, si no hay mas paginas despues de esta se muestra desabilitado #}
        {% if page >= totalPages - 1 or totalPages <= 0 %}
            <button class="p-2 flex justify-center items-center bg-white/10 text-gray-500 rounded-md rounded-br-xl rounded-tr-xl">
                <span class="icon-[material-symbols--arrow-forward]"></span>
            </button>
        {% else %}
            <button class="boton-pagina-siguiente p-2 flex justify-center items-center bg-blue-400/40 text-blue-200 rounded-md rounded-br-xl rounded-tr-xl">
                <span class="icon-[material-symbols--arrow-forward]"></span>
            </button>
        {% endif %}

    </section>

    {# Etiqueta que muestra la cantidad de resultados encontrados en la busqueda, si son 0 toma un color rojo oscuro #}
    <span class="py-2 px-4 text-sm 
        {{
            "bg-blue-400/30 text-white/60" 
            if totalFoundFilms > 0 
            else 
            "bg-red-400/30 text-white/60"
        }}
        rounded-3xl">{{totalFoundFilms}} de {{totalFilms}} resultados
    </span>

</section>

{# Listado de peliculas #}
<section class="flex flex-col gap-4 mb-15 md:mb-0" id="listadoPeliculas">
    {% for film in films %}
        {% include "components/film_resultado_busqueda.njk" %}
    {% endfor %}
</section>

{% endblock %}
