{% extends "base.njk" %}

{% block titulo %}Peliculas | Listado{% endblock %}

{% block scripts %} 

<script type="module" src="http://localhost:5173/js/buscador_peliculas.js"></script>

{% endblock %}

{% block contenido %}
<section class="bg-white/10 rounded-md p-4">
    <form class="flex gap-2" action="/films" method="get" id="formulario-buscador">
        <input type="hidden" id="paginaABuscar" name="paginaABuscar" value="{{page + 1}}">
        <section class="text-input p-0 m-0 flex items-center">
            <label for="titulo" class="icon-[streamline-plump--film-slate-remix] size-4 ml-3 bg-gray-400"></label>
            <input value="{{params.titulo}}" placeholder="Titulo" class="p-2 w-60 rounded-md outline-0" type="text" name="titulo" id="titulo">
        </section>
        <section class="text-input p-0 m-0 flex items-center">
            <label for="titulo" class="icon-[mdi--calendar] size-5 ml-3 bg-gray-400"></label>
            <input value='{{params.anyo}}' placeholder="Año" class="p-2 w-30 rounded-md outline-0" min=0 type="number" name="anyo" id="anyo">
        </section>
        <section class="text-input p-0 m-0 flex items-center">
            <label for="director" class="icon-[material-symbols--person] size-5 ml-2 bg-gray-400"></label>
            <input value='{{params.director}}' placeholder="Director" class="p-2 w-30 rounded-md outline-0" type="text" name="director" id="director">
        </section>
        <section class="text-input p-0 m-0 flex items-center">
            <label for="director" class="icon-[mdi--sort-alphabetical-ascending] size-5 ml-2 bg-gray-400"></label>
            <select class="p-2 w-35 rounded-md outline-0 text-gray-400"  type="text" name="orden" id="orden">
                <option {{"selected" if params.orden == "asc"}} value="asc" class="bg-gray-800">Ascendente</option>
                <option {{"selected" if params.orden == "desc"}} value="desc" class="bg-gray-800">Descendente</option>
            </select>
        </section>
        <section class="text-input p-0 m-0 flex items-center">
            <label for="max-resultados" class="icon-[mdi--format-list-numbered] size-5 ml-2 bg-gray-400"></label>
            <!-- si el valor de limite devuelto del servidor es 10, no se mostrara el valor ya que es el que la base de datos tiene por defecto -->
            <input value='{{limit if limit != 10}}' min="5" max="20" placeholder="Ver 10..." class="p-2 w-30 rounded-md outline-0" type="number" name="max_resultados" id="max-resultados">
        </section>
        <button type="submit" class="button bg-blue-800/60 text-blue-300 hover:text-white hover:bg-blue-600/70 cursor-pointer">
            <span class="icon-[material-symbols--search] size-5"></span>
            <span>Buscar</span>
        </button>
        <button type="reset" class="button bg-red-800/60 text-red-300 hover:text-white hover:bg-red-600/70 cursor-pointer">
            <span class="icon-[pajamas--remove] size-4"></span>
            <span>Limpiar</span>
        </button>
    </form>
</section>
<!-- lista de paginas -->
<section class="flex flex-row justify-between items-center py-4">
    <section class="flex flex-row gap-2">
        {% if page <= 0 or totalPages <= 0 %}
            <button class="p-2 flex justify-center items-center bg-white/10 text-gray-500 rounded-md">
                <span class="icon-[material-symbols--arrow-back]"></span>
            </button>
        {% else %}
            <button class="boton-pagina-anterior p-2 flex justify-center items-center bg-blue-400/40 text-blue-200 rounded-md">
                <span class="icon-[material-symbols--arrow-back]"></span>
            </button>
        {% endif %}
        {% for p in range(1, totalPages+1) %}
            <div>
                {% if (page+1) == p %}
                    <button class="boton-pagina py-2 px-4 bg-blue-400/40 text-blue-200 scale-105 rounded-md">{{p}}</button>
                {% else %}
                    <button class="boton-pagina py-2 px-4 bg-white/10 hover:bg-white/15 text-gray-500 hover:scale-105 rounded-md">{{p}}</button>
                {% endif %}
            </div>
        {% endfor %}
        {% if page >= totalPages - 1 or totalPages <= 0 %}
            <button class="p-2 flex justify-center items-center bg-white/10 text-gray-500 rounded-md">
                <span class="icon-[material-symbols--arrow-forward]"></span>
            </button>
        {% else %}
            <button class="boton-pagina-siguiente p-2 flex justify-center items-center bg-blue-400/40 text-blue-200 rounded-md">
                <span class="icon-[material-symbols--arrow-forward]"></span>
            </button>
        {% endif %}
    </section>
    <span class="py-2 px-4 text-sm 
        {{"bg-blue-400/30 text-white/60" 
            if totalFoundFilms > 0 
            else "bg-red-400/30 text-white/60"}}
            rounded-3xl">{{totalFoundFilms}} de {{totalFilms}} resultados
    </span>

</section>
</section>
<section class="flex flex-col gap-4" id="listadoPeliculas">
    {% for film in films %}
    <section class="film-item flex flex-row items-center justify-between gap-6 p-4">
        <section class="flex gap-10">
            <div class="w-80 h-80 rounded-md shrink-0">
                {% if film.imagen == undefined or film.imagen == "" %}
                    <div class="flex flex-col border border-white/20 rounded-md h-full justify-center items-center">
                        <span class="icon-[mdi-light--picture] size-30 text-white/20"></span>
                    </div>
                {% else %}
                    <a href="/films/{{ film._id }}">
                        <img class="object-cover rounded-md h-full" src="{{film.imagen}}">
                    </a>
                {% endif %}
            </div>
            <div class="flex flex-col justify-between gap-2 py-2">
                <section>
                    <a href="/films/{{ film._id }}" class="titulo text-lg p-1 hover:underline cursor-pointer">
                        {{film.titulo}}
                    </a>
                    <p class="p-1">{{film.sinopsis}}</p>
                </section>

                {# Valoración media #}
                {% if film.mediaValoracion > 0 %}
                    <section class="flex items-center gap-2 text-gray-300 text-sm mt-1">
                        <span class="tag border border-yellow-600 flex flex-row gap-2 p-2">
                            <span class="icon-[noto--star] size-4"></span>
                            <span>{{ film.mediaValoracion }} / 5</span>
                        </span>
                    </section>
                {% endif %}

                <section class="flex flex-row gap-3 mt-2">
                    <section class="flex items-center gap-2 text-gray-300 text-sm">
                        <span class="tag border border-purple-600 flex flex-row gap-2 p-2">
                            <span class="icon-[streamline-plump--film-slate-remix] size-4.5"></span>
                            <span>{{film.genero}}</span>
                        </span>
                    </section>
                    <section class="flex items-center gap-2 text-gray-300 text-sm">
                        <span class="tag border border-blue-600 flex flex-row gap-2 p-2">
                            <span class="icon-[mdi--calendar] size-4.5"></span>
                            <span class="anyo">{{film.anyo}}</span>
                        </span>
                    </section>
                    <section class="flex items-center gap-2 text-gray-300 text-sm">
                        <span class="tag border border-green-600 flex flex-row gap-2 p-2">
                            <span class="icon-[material-symbols--person] size-5"></span>
                            <span class="director">{{film.director}}</span>
                        </span>
                    </section>
                </section>
            </div>
        </section>
        <div class="flex flex-row items-center gap-4">
            <a href="/films/editar/{{ film._id }}"
                class="flex items-center justify-center p-2 rounded-lg bg-blue-600/20 text-blue-400 hover:bg-blue-600 hover:text-white transition-colors cursor-pointer">
                <span class="icon-[material-symbols--edit-outline] size-5"></span>
            </a>
            <form action="/films/{{ film._id }}" method="post" class="inline m-0 p-0">
                <input type="hidden" name="_method" value="delete" />
                <button type="submit"
                    class="flex items-center justify-center p-2 rounded-lg bg-red-600/20 text-red-400 hover:bg-red-600 hover:text-white transition-colors cursor-pointer border-0"
                    title="Eliminar">
                    <span class="icon-[material-symbols--delete-outline] size-5"></span>
                </button>
            </form>
        </div>
    </section>
    {% endfor %}
</section>

{% endblock %}
