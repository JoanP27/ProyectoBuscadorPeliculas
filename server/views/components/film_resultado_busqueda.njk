<section class="film-item flex flex-col md:flex-row items-center md:justify-between gap-6 p-4">
    {# Seccion de contenido de la tarjeta #}
    <section class="flex flex-col md:flex-row gap-10 w-full">
        {# Imagen de la pelicula, si la pelicula tiene una imagen se muestra, sino se deja un icono por defecto #}
        <div class="w-full md:w-80 h-80  rounded-md shrink-0">
            {% if film.imagen == undefined or film.imagen == "" %}
                <div class="flex flex-col border border-white/20 rounded-md h-full justify-center items-center">
                    <span class="icon-[mdi-light--picture] size-30 text-white/20"></span>
                </div>
            {% else %}
                <a href="/films/{{ film._id }}">
                    <img class="object-cover rounded-md size-full" src="{{film.imagen}}">
                </a>
            {% endif %}
        </div>

        {# Datos de la pelicula #}
        <div class="flex flex-col justify-between gap-2 py-2">

            {# Titulo, al hacer click te lleva a la vista de detalles #}
            <section>
                <a href="/films/{{ film._id }}" class="titulo text-2xl p-1 hover:underline cursor-pointer">
                    {{film.titulo}}
                </a>
                <p class="p-1 text-gray-400">{{film.sinopsis}}</p>
            </section>

            {# Valoración media #}
            {% if film.mediaValoracion > 0 %}
                <section class="flex items-center gap-2 text-gray-300 text-sm mt-1">
                    <span class="tag border border-yellow-600 flex flex-row gap-2 p-2">
                        <span class="icon-[noto--star] size-4"></span>
                        <span>{{ film.mediaValoracion }} / 5</span>
                    </span>
                </section>
            {% endif %}

            {# Etquetas de genero, año de publicacion y director #}
            <section class="flex flex-row gap-3 mt-2">

                <section class="flex items-center gap-2 text-gray-300 text-sm">
                    <span class="tag border  border-purple-600  bg-purple-800/20 flex flex-row gap-2 p-2">
                        <span class="icon-[streamline-plump--film-slate-remix] size-4.5"></span>
                        <span>{{film.genero}}</span>
                    </span>
                </section>

                <section class="flex items-center gap-2 text-gray-300 text-sm">
                    <span class="tag border border-blue-600 bg-blue-800/20 flex flex-row gap-2 p-2">
                        <span class="icon-[mdi--calendar] size-4.5"></span>
                        <span class="anyo">{{film.anyo}}</span>
                    </span>
                </section>

                <section class="flex items-center gap-2 text-gray-300 text-sm">
                    <span class="tag border border-green-600 flex bg-green-800/20 flex-row items-center gap-2 p-2">
                        <span class="icon-[material-symbols--person] size-5"></span>
                        <span class="director">{{film.director}}</span>
                    </span>
                </section>

            </section>
        </div>
    </section>

    {# Botones de editar y eliminar la pelicula #}
    <div class="flex flex-row md:flex-col p-2 w-full md:p-0 md:w-auto items-start md:items-center gap-6">

        <a href="/films/editar/{{ film._id }}"
            class="flex items-center justify-center p-4 rounded-lg bg-blue-600/20 text-blue-400 hover:bg-blue-600 hover:text-white transition-colors cursor-pointer">
            <span class="icon-[material-symbols--edit-outline] size-5"></span>
        </a>

        <form action="/films/{{ film._id }}" method="post" class="inline m-0 p-0">
            <input type="hidden" name="_method" value="delete" />
            <button type="submit"
                class="flex items-center justify-center p-4 rounded-lg bg-red-600/20 text-red-400 hover:bg-red-600 hover:text-white transition-colors cursor-pointer border-0"
                title="Eliminar">
                <span class="icon-[material-symbols--delete-outline] size-5"></span>
            </button>
        </form>
        
    </div>
</section>