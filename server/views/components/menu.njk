<header>
    <section class="bg-gray-900 flex h-20 items-center justify-between px-4">
        <div class="text-2xl text-gray-50 p-2">Peliculas</div>
        <nav>
            <ul class="list-none flex items-center">
    <li><a class="p-2 text-gray-50" href="/films">Listado de peliculas</a></li>
    <li><a class="p-2 text-gray-50" href="/films/nuevo">Anyadir pelicula</a></li>
    <li>
        <a class="p-2 text-gray-50 flex items-center gap-1" href="/cart">
            <span class="icon-[mdi--cart] size-5"></span>
            Carrito
            {% if session.cart and session.cart | length > 0 %}
                <span class="ml-1 bg-red-500 text-white text-xs
                             font-bold rounded-full w-5 h-5 flex items-center justify-center">
                    {{ session.cart | length }}
                </span>
            {% endif %}
        </a>
    </li>
</ul>
        </nav>
    </section>
</header>