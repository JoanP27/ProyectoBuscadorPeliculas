{% extends "base.njk" %}

{% block titulo %}Peliculas | {{ film.titulo }}{% endblock %}

{% block contenido %}

<div class="max-w-3xl mx-auto mt-8 space-y-8 px-4">

    {# ── Datos de la película ── #}
    <div class="bg-white rounded-2xl shadow p-6">
        <h1 class="text-3xl font-bold mb-4 text-slate-800">{{ film.titulo }}</h1>
        <p><strong>Director:</strong> {{ film.director }}</p>
        <p><strong>Año:</strong> {{ film.anyo }}</p>
        <p><strong>Género:</strong> {{ film.genero }}</p>
        <p class="mt-2 text-slate-600">{{ film.sinopsis }}</p>

        {# Valoración media #}
        {% if mediaValoracion > 0 %}
            <p class="mt-3 text-yellow-500 font-semibold">
                ⭐ Valoración media: {{ mediaValoracion }} / 5
            </p>
        {% else %}
            <p class="mt-3 text-slate-400">Sin valoraciones todavía</p>
        {% endif %}

        {# Botones #}
        <div class="flex gap-3 mt-4">
            {# Abrir modal de comentario #}
            <button onclick="document.getElementById('modalComentario').showModal()"
                class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-xl">
                💬 Añadir comentario
            </button>

            {# Añadir al carrito #}
            <form action="/cart/anyadir/{{ film.id }}" method="post">
                <button type="submit"
                    class="bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2 px-4 rounded-xl">
                    🛒 Añadir al carrito
                </button>
            </form>
        </div>
    </div>

    {# ── Modal para añadir comentario ── #}
    {# El elemento <dialog> es HTML nativo, no necesita librerías #}
    <dialog id="modalComentario"
        class="rounded-2xl shadow-xl p-0 w-full max-w-lg backdrop:bg-black/50">

        <div class="bg-white rounded-2xl overflow-hidden">
            <div class="bg-gray-800 px-6 py-4">
                <h3 class="text-lg font-semibold text-white">Publicar comentario</h3>
            </div>

            {# El form apunta a /details/ID con POST #}
            <form action="/details/{{ film.id }}" method="post" class="px-6 py-4 space-y-4">

                {# Nick #}
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">
                        Tu nombre (nick):
                    </label>
                    <input type="text" name="nick" required
                        placeholder="¿Cómo te llamas?..."
                        class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>

                {# Texto del comentario #}
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">
                        Comentario:
                    </label>
                    <textarea name="texto" required rows="4"
                        placeholder="¿Qué opinas de la película?..."
                        class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
                </div>

                {# Valoración con estrellas interactivas #}
                {# Usamos radio buttons invisibles con estrellas encima #}
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">
                        Valoración:
                    </label>
                    <select name="valoracion" required
                        class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="">Elige una valoración</option>
                        <option value="1">1 ⭐- Muy mala</option>
                        <option value="2">2 ⭐⭐- Mala</option>
                        <option value="3">3 ⭐⭐⭐- Regular</option>
                        <option value="4">4 ⭐⭐⭐⭐- Buena</option>
                        <option value="5">5 ⭐⭐⭐⭐⭐- Excelente</option>
                    </select>
                </div>

                {# Botones del modal #}
                <div class="flex justify-end gap-3 pt-2">
                    <button type="button"
                        onclick="document.getElementById('modalComentario').close()"
                        class="bg-slate-200 hover:bg-slate-300 text-slate-700 font-semibold py-2 px-4 rounded-xl text-sm">
                        Cancelar
                    </button>
                    <button type="submit"
                        class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-xl text-sm">
                        Publicar
                    </button>
                </div>

            </form>{# ← el form se cierra ANTES de cerrar el modal #}
        </div>
    </dialog>

    {# ── Listado de comentarios ── #}
    <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-xl font-bold mb-4 text-slate-700">
            Comentarios ({{ comentarios | length }})
        </h2>

        {% if comentarios | length > 0 %}
            <ul class="space-y-4">
                {% for c in comentarios %}
                    <li class="border-b border-slate-100 pb-4">
                        <div class="flex justify-between items-center">
                            <span class="font-semibold text-slate-800">{{ c.nick }}</span>
                            <span class="text-xs text-slate-400">{{ c.fecha }}</span>
                        </div>
                        {# Estrellas del comentario #}
                    
                        <p class="text-slate-600 text-sm">{{ c.texto }}</p>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p class="text-slate-400">No hay comentarios todavía. ¡Sé el primero!</p>
        {% endif %}
    </div>

    {# ── Recomendaciones ── #}
    {% if recomendaciones | length > 0 %}
        <div class="bg-white rounded-2xl shadow p-6">
            <h2 class="text-xl font-bold mb-4 text-slate-700">🎬 Te puede interesar</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                {% for r in recomendaciones %}
                    <a href="/details/{{ r.id }}"
                        class="block bg-slate-50 hover:bg-slate-100 rounded-xl p-4 border border-slate-200 transition">
                        <p class="font-semibold text-slate-800">{{ r.titulo }}</p>
                        <p class="text-sm text-slate-500">{{ r.director }} · {{ r.anyo }}</p>
                        <p class="text-xs text-slate-400 mt-1">{{ r.genero }}</p>
                    </a>
                {% endfor %}
            </div>
        </div>
    {% endif %}

</div>

{% endblock %}