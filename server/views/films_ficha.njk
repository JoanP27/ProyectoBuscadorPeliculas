{% extends "base.njk" %}

{% block titulo %}Peliculas | {{ film.titulo }}{% endblock %}

{% block contenido %}

<div class="max-w-3xl mx-auto mx-auto sm:mt-8 space-y-4 sm:space-y-8  px-2 sm:px-4">

    {# Card principal #}
    <div class="bg-white rounded-2xl shadow p-3 sm:p-6">
        <div class=" flex flex-col sm:flex-row gap-6">

            {# Imagen a la izquierda #}
            <img src="{{ film.imagen }}" alt="{{ film.titulo }}"
                class="w-full sm:w-48 max-h-72 sm:max-h-none object-cover rounded-xl flex-shrink-0">

            {# Datos a la derecha #}
            <div class="flex flex-col flex-1">
                <h1 class="text-2xl sm:text-3xl font-bold mb-4 text-slate-800">{{ film.titulo }}</h1>
                <p class="mt-2 text-slate-600"><strong>Director:</strong> {{ film.director }}</p>
                <p class="mt-2 text-slate-600"><strong>Año:</strong> {{ film.anyo }}</p>
                <p class="mt-2 text-slate-600"><strong>Género:</strong> {{ film.genero }}</p>
                <p class="mt-2 text-slate-600">{{ film.sinopsis }}</p>

                {# Valoración media #}
                <div class="flex items-center mt-3">
                    {% if mediaValoracion > 0 %}
                        {% for i in range(0, 5) %}
                            <span class="icon-[noto--star]"></span>
                        {% endfor %}
                        <p class="ms-2 text-sm font-bold text-slate-700">{{ mediaValoracion }}</p>
                        <span class="w-1 h-1 mx-1.5 bg-slate-400 rounded-full"></span>
                        <span class="text-sm text-slate-500">{{ comentarios | length }} reseñas</span>
                    {% else %}
                        <span class="text-slate-400 text-sm">Sin valoraciones todavía</span>
                    {% endif %}
                </div>

                {# Botones #}
                <div class="flex flex-col sm:flex-row gap-3 mt-4">
                    {% include "detail_nuevo.njk" %}
                    <form action="/cart/anyadir/{{ film.id }}" method="post">
                        <button type="submit"
                            class="w-full sm:w-auto bg-purple-900 hover:bg-purple-600 text-white font-semibold py-2 px-4 rounded-xl">
                            <span class="icon-[mdi--cart]"></span> Añadir al carrito
                        </button>
                    </form>
                </div>

            </div> 
        </div>     
    </div>         

    {# Card comentarios #}
    <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-xl font-bold mb-4 text-slate-700">
            Comentarios ({{ comentarios | length }})
        </h2>

        {% if comentarios | length > 0 %}
            <ul class="space-y-6">
                {% for c in comentarios %}
                    <li class="border-b border-slate-100 pb-6">
                        <article>
                            <div class="flex items-center mb-2">
                                <p class="font-semibold text-slate-800">{{ c.nick }}</p>
                            </div>

                            {# Estrellas del comentario #}
                            <div class="flex items-center mb-1 space-x-1">
                            {% for i in range(0, 5) %}
                                {% if i < c.valoracion %}
                                    <span class="icon-[noto--star] size-5"></span>
                                {% else %}
                                    <span class="icon-[noto--star-outlined] size-5"></span>
                                {% endif %}
                            {% endfor %}
                            </div>

                            <footer class="mb-2 mt-1">
                                <time class="block text-sm text-slate-400">
                                    Publicado el {{ c.fechaFormateada }}
                                </time>
                            </footer>

                            <p class="mb-2 text-slate-600">{{ c.texto }}</p>
                        </article>

                        <aside>
                            <div class="flex items-center mt-3">
                                <button type="button"
                                    onclick="document.getElementById('modalEditar-{{ c._id }}').showModal()"
                                    class="border border-slate-300 hover:bg-slate-100 text-slate-700
                                           font-medium rounded-lg text-xs px-3 py-1.5">
                                    Editar comentario
                                </button>

                                <form action="/details/{{ c._id }}" method="post">
                                    <input type="hidden" name="_method" value="delete">
                                    <button type="submit"
                                        class="border border-red-300 hover:bg-red-100 text-red-600
                                               font-medium rounded-lg text-xs ml-2 px-3 py-1.5">
                                        Eliminar
                                    </button>
                                </form>
                            </div>
                        </aside>

                        {% include "detail_editar.njk" %}
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p class="text-slate-400">No hay comentarios todavía.</p>
        {% endif %}
    </div>

    {# Card recomendaciones #}
    {% if recomendaciones | length > 0 %}
        <div class="bg-white rounded-2xl shadow p-6">
            <h2 class="text-xl font-bold mb-4 text-slate-700">
                <span class="icon-[ion--film-marker]"></span> Recomendaciones
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                {% for r in recomendaciones %}
                    <a href="/films/{{ r._id }}"
                        class="block bg-slate-50 hover:bg-slate-100 rounded-xl p-4
                               border border-slate-200 transition">
                        <p class="font-semibold text-slate-800">{{ r.titulo }}</p>
                        <p class="text-sm text-slate-500">{{ r.director }} · {{ r.anyo }}</p>
                        <p class="text-xs text-slate-400 mt-1">{{ r.genero }}</p>
                    </a>
                {% endfor %}
            </div>
        </div>
    {% endif %}

</div>

{% endblock %}